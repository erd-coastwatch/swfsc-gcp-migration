        :title = "Primary Productivity, VIIRS NOAA-20 Science Quality, Global, 4km, 2018-present (1 Day Composite)" ;
        :Westernmost_Easting = -89.97916f ;
        :history = "Chlorophyll a, PAR, and SST satellite data were applied to the equation of Behrenfeld and Falkowski, 1997" ;
