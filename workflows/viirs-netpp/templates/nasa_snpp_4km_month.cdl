        :history = "Chlorophyll a, PAR, and SST satellite data from VIIRS SNPP were applied to the equation of Behrenfeld and Falkowski, 1997 to make daily composite files. The monthly file are means of the daily files." ;
        :id = "productivity_snpp_mday" ;
        :institution = "NOAA CoastWatch West Coast Node" ;
        :instrument = "VIIRS" ;
        :keywords = "Earth Science > Oceans > Ocean Chemistry > Pigments > Chlorophyll; Earth Science > Oceans > Ocean Chemistry > Chlorophyll, Earth Science > Oceans > Ocean Optics > Photosynthetically Available Radiation" ;
