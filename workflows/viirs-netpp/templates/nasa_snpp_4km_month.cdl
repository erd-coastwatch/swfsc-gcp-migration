        :project = "CoastWatch Primary Productivity Project" ;
        :platform = "Suomi-NPP" ;
        :publisher_name = "NOAA/STAR/NESDIS/CoastWatch/West Coast Node" ;
        :publisher_email = "coastwatch.info@noaa.gov" ;
