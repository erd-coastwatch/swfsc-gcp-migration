        :processing_level = "L3 Mapped" ;
        :reference = "M.J. Behrenfeld and P. G. Falkowski, Photosynthetic rates derived from satellite-based chlorophyll concentration, Limnol. Oceanogr. 42(l), 1997. 1-20" ;
        :source = "satellite observations from VIIRS-Suomi-NPP" ;
        :summary = "The VIIRS SNPP Primary Productivity product estimates net carbon fixation by phytoplankton in oceanic waters using the algorithm of Behrenfeld and P. G. Falkowski (1997). Data sources used as in the algorithm are chlorophyll a, SST and PAR values from VIIRS SNPP. The chlorophyll a, SST, and PAR data used as inputs to the algorithm are included in the dataset. Data are mapped to a NASA 4km Standard Mapped Image. The monthly data are means of the daily composites" ;
        :temporal_range = "month" ;
        :time_coverage_resolution = "P1M" ;
        :title = "Primary Productivity, VIIRS SNPP, Global, 2012-present, EXPERIMENTAL (Monthly Composite)" ;
